{
  "name": "proofsheet",
  "version": "0.3.0",
  "private": true,
  "description": "Image generation, refinement, and reusable themes powered by Nano Banana (Gemini) or gpt-image-1 (OpenAI).",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "gemini": "node bin/gemini-image.js",
    "openai": "node bin/openai-image.js",
    "dev:gemini": "tsx src/gemini-image.ts",
    "dev:openai": "tsx src/openai-image.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
}
